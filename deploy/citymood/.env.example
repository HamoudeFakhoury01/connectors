# ============================================================================
# CityMood — variables d'environnement de la boîte INGESTION (connecteur SFDC)
# ----------------------------------------------------------------------------
# Copie ce fichier en `.env` (NE PAS versionner le .env rempli) :
#     cp .env.example .env
# Puis remplis les lignes vides ci-dessous quand on reçoit les infos d'Issy.
# ============================================================================

# --- Salesforce Issy (à remplir quand Issy/Mohamed nous donne les creds) ----
# Sous-domaine SFDC : si l'URL est `foo.my.salesforce.com`, mettre `foo`.
SFDC_DOMAIN=
# Consumer Key de la Connected App (OAuth Client Credentials).
SFDC_CLIENT_ID=
# Consumer Secret de la Connected App.
SFDC_CLIENT_SECRET=
# Champs Case à extraire (liste séparée par des virgules). Défaut raisonnable :
CASE_FIELDS=Subject, Description, CaseNumber, Status

# --- Chaîne CityMood : anonymizer -> webhook --------------------------------
# URL interne du conteneur anonymizer (laisser tel quel : nom de service compose).
ANONYMIZER_URL=http://anonymizer-api:8000
# Endpoint webhook CityMood (cloud OVH) — fourni par l'équipe CityMood.
CITYMOOD_INGEST_URL=
# UUID du tenant Issy (multi-tenant) — fourni par l'équipe CityMood.
CITYMOOD_TENANT_ID=
# Secret partagé du webhook — fourni par l'équipe CityMood.
WEBHOOK_SECRET=
